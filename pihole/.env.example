# Copy to .env (next to docker-compose.yml) and adjust.
# bootstrap.sh / the Ansible pihole role / the logon task all auto-fill PIHOLE_BIND_IP
# with the current WSL eth0 IP (`hostname -I | cut -d' ' -f1`).

# REQUIRED — the WSL2 eth0 IP Pi-hole binds DNS to (changes across reboots; auto-detected).
PIHOLE_BIND_IP=

# Web dashboard port on the host (http://localhost:<port>/admin)
PIHOLE_WEB_PORT=8053

# Admin password — CHANGE THIS for your own deployment.
PIHOLE_PASSWORD=change-me-please

# Timezone (affects dashboard timestamps)
PIHOLE_TZ=America/Sao_Paulo

# Upstream resolvers for non-blocked queries (semicolon-separated)
PIHOLE_UPSTREAMS=1.1.1.1;1.0.0.1

# Container name
PIHOLE_CONTAINER=pihole
