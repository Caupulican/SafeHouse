# Secrets / runtime (never commit)
pihole/.env
.env

# Pi-hole runtime data (regenerated by gravity)
etc-pihole/
**/etc-pihole/

# Capture artifacts
*.etl
*.pcapng
*.cap

# Logs
*.log

# Traffic logs (local/personal - records every server this machine contacts; never commit)
logs/*.csv
logs/*.db
logs/*.sqlite
!logs/.gitkeep
!logs/README.md

# OS cruft
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
