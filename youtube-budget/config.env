# SafeHouse — YouTube daily watch-time budget: configuration (sample, documented).
#
# This file is sourced by youtube-budget.sh (daemon), youtube-budget-ctl.sh (parent
# CLI) and install.sh. Every value can also be overridden from the environment
# (the daemon/CLI read `${VAR:-default}`), so this file is the persisted default.
# `set-limit` rewrites DAILY_LIMIT_MIN here in place; everything else you edit by hand.
#
# All keys are simple KEY=value (no spaces around '='), shell-sourced — quote values
# that contain spaces.

# --- Budget -----------------------------------------------------------------
# Minutes of *measured* YouTube watching allowed per local day before the block
# arms. This is the steady-state allowance; per-day extensions are granted with
# `youtube-budget-ctl.sh grant <minutes>` (stored as bonus_sec in the state file)
# and do not change this number.
DAILY_LIMIT_MIN=60

# --- Sampling / detection ---------------------------------------------------
# How often (seconds) the daemon wakes, looks at the Pi-hole query log, and (if
# active) bills SAMPLE_SEC against the budget. Smaller = finer accounting + faster
# enforcement, but more wakeups. 20s is a good balance: at most ~20s of slop at the
# cutoff and ~20s billing granularity.
SAMPLE_SEC=20

# Sliding detection window (seconds). A sample counts as "active" if ANY allowed
# YouTube-content query (see detect-domains.txt) appears in the last WINDOW_SEC.
# This MUST be comfortably larger than SAMPLE_SEC and larger than Pi-hole FTL's
# DB-flush interval: FTL buffers queries in memory and flushes to pihole-FTL.db
# only every ~30-60s, so a too-short window would miss recent watching. 240s (4 min)
# absorbs that flush lag and bridges the gaps between a video's sparse DNS lookups
# (a single long video may only re-resolve googlevideo.com every couple of minutes).
WINDOW_SEC=240

# --- Pi-hole / infrastructure ----------------------------------------------
# Docker container name running Pi-hole (matches scripts/load-blocklists.sh).
PIHOLE_CONTAINER=pihole

# Live Windows hosts file (the enforcement target). The daemon splices a marked
# YouTube block in/out of this file, byte-preserving (CRLF header + LF body), the
# same way windows/parental-toggle.ps1 does. Reused for browser/app-agnostic
# enforcement: anything resolving names on this machine is affected.
HOSTS_PATH=/mnt/c/Windows/System32/drivers/etc/hosts

# Where the daemon persists today's accounting. Root-owned, 0600 — the kid has no
# WSL account, so state and enforcement live on the side they cannot reach.
STATE_FILE=/var/lib/safehouse/youtube-budget.json

# Display name used in the hosts marker (`# === Parental block: <BLOCK_NAME> ... ===`)
# and to pick the enforcement host list windows/parental-blocks/<lowercased>.txt.
# Leave as "YouTube" to share the list/markers with parental-toggle.ps1.
BLOCK_NAME=YouTube

# Daily-reset timezone. "local" = the WSL host's local date (`date +%F`). Set to an
# IANA zone (e.g. America/Sao_Paulo) to reset the budget at midnight in that zone
# regardless of host TZ.
TZ_RESET=local
